# GZCTF Discord Notification Bot Example Environment File

# GZCTF API
GZCTF_BASE_URL=https://ctf.example.com
GZCTF_API_TOKEN=
GZCTF_USERNAME=
GZCTF_PASSWORD=

# Discord Bot
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# Bot Configuration
GAME_ID=
POLL_INTERVAL=30
ENABLE_NOTICES=true
ENABLE_EVENTS=true
DEBUG=false

# Channel names (optional, default: notification, event)
NOTIFICATION_CHANNEL_NAME=notification
EVENT_CHANNEL_NAME=event 